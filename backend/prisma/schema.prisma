generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Specialty {
  id            String         @id @default(uuid())
  name          String         @unique
  createdAt     DateTime       @default(now())

  professionals Professional[]

  @@map("specialties")
}

model Professional {
  id          String    @id @default(uuid())
  fullName    String
  specialtyId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  specialty   Specialty @relation(fields: [specialtyId], references: [id])

  @@map("professionals")
}

model Patient {
  id        String   @id @default(uuid())
  fullName  String
  cpf       String   @unique
  birthDate DateTime @db.Date
  phone     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("patients")
}